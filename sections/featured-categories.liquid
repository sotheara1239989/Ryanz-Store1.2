<section class="section" id="featured-categories">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow">{{ section.settings.eyebrow | default: 'Shop by Category' }}</span>
      <h2 class="section-title">{{ section.settings.heading | default: 'Find Your Gear' }}</h2>
      <p class="section-subtitle">{{ section.settings.subheading | default: 'Explore our full range of premium gaming equipment' }}</p>
    </div>

    <div class="reveal-stagger" style="display:grid;grid-template-columns:repeat(4,1fr);gap:1.25rem">
      {%- for block in section.blocks -%}
        {%- assign collection = collections[block.settings.collection] -%}
        <a
          href="{{ collection.url | default: block.settings.link | default: '/collections/all' }}"
          class="category-card"
          {{ block.shopify_attributes }}
          style="aspect-ratio:{{ block.settings.aspect_ratio | default: '3/4' }}"
        >
          {%- if block.settings.image != blank -%}
            <img
              class="category-card__bg"
              src="{{ block.settings.image | img_url: '600x' }}"
              alt="{{ block.settings.title | default: collection.title }}"
              loading="lazy"
              width="600"
              height="800"
            >
          {%- elsif collection.image != blank -%}
            <img
              class="category-card__bg"
              src="{{ collection.image | img_url: '600x' }}"
              alt="{{ collection.title }}"
              loading="lazy"
              width="600"
              height="800"
            >
          {%- else -%}
            <div class="category-card__bg" style="background:linear-gradient(135deg, var(--color-surface-2), var(--color-surface-3));display:flex;align-items:center;justify-content:center;font-size:4rem;">
              {{ block.settings.emoji | default: '🎮' }}
            </div>
          {%- endif -%}

          <div class="category-card__overlay">
            {%- if block.settings.emoji != blank -%}
              <div class="category-card__icon">{{ block.settings.emoji }}</div>
            {%- endif -%}
            <div class="category-card__name">
              {{ block.settings.title | default: collection.title | default: 'Category' }}
            </div>
            {%- if collection.products_count > 0 -%}
              <div class="category-card__count">{{ collection.products_count }} Products</div>
            {%- elsif block.settings.product_count != blank -%}
              <div class="category-card__count">{{ block.settings.product_count }}</div>
            {%- endif -%}
          </div>
        </a>
      {%- else -%}
        {%- assign default_cats = 'Gaming Keyboards,Gaming Mice,Headsets,Controllers,Mouse Pads,Gaming Chairs,Streaming Gear,RGB Accessories' | split: ',' -%}
        {%- assign default_emojis = '⌨️,🖱️,🎧,🎮,🖥️,🪑,📡,💡' | split: ',' -%}
        {%- for cat in default_cats -%}
          <div class="category-card" style="cursor:default">
            <div class="category-card__bg" style="background:linear-gradient(135deg,var(--color-surface-2),var(--color-surface-3));display:flex;align-items:center;justify-content:center;font-size:3.5rem">
              {{ default_emojis[forloop.index0] }}
            </div>
            <div class="category-card__overlay">
              <div class="category-card__icon">{{ default_emojis[forloop.index0] }}</div>
              <div class="category-card__name">{{ cat }}</div>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.show_cta -%}
      <div style="text-align:center;margin-top:2.5rem">
        <a href="{{ section.settings.cta_link | default: '/collections' }}" class="btn btn--secondary">
          {{ section.settings.cta_text | default: 'View All Categories' }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  @media (max-width:1024px) { #featured-categories .reveal-stagger > div, #featured-categories .reveal-stagger > a { grid-template-columns: repeat(2,1fr); } }
  @media (max-width:1024px) { #featured-categories [style*="grid-template-columns:repeat(4"] { grid-template-columns: repeat(2,1fr) !important; } }
  @media (max-width:640px)  { #featured-categories [style*="grid-template-columns:repeat(4"] { grid-template-columns: repeat(2,1fr) !important; } }
</style>

{% schema %}
{
  "name": "Featured Categories",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Shop by Category" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Find Your Gear" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Explore our full range of premium gaming equipment" },
    { "type": "checkbox", "id": "show_cta", "label": "Show View All Button", "default": true },
    { "type": "text", "id": "cta_text", "label": "CTA Button Text", "default": "View All Categories" },
    { "type": "url", "id": "cta_link", "label": "CTA Link" }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Override Image" },
        { "type": "text", "id": "title", "label": "Override Title" },
        { "type": "text", "id": "emoji", "label": "Category Icon (emoji)", "default": "🎮" },
        { "type": "text", "id": "product_count", "label": "Override Product Count Text" },
        { "type": "url", "id": "link", "label": "Override Link" },
        { "type": "text", "id": "aspect_ratio", "label": "Aspect Ratio (e.g. 3/4)", "default": "3/4" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured Categories",
      "blocks": [
        { "type": "category", "settings": { "title": "Gaming Keyboards", "emoji": "⌨️" } },
        { "type": "category", "settings": { "title": "Gaming Mice", "emoji": "🖱️" } },
        { "type": "category", "settings": { "title": "Headsets", "emoji": "🎧" } },
        { "type": "category", "settings": { "title": "Controllers", "emoji": "🎮" } },
        { "type": "category", "settings": { "title": "Mouse Pads", "emoji": "🖥️" } },
        { "type": "category", "settings": { "title": "Gaming Chairs", "emoji": "🪑" } },
        { "type": "category", "settings": { "title": "Streaming Gear", "emoji": "📡" } },
        { "type": "category", "settings": { "title": "RGB Accessories", "emoji": "💡" } }
      ]
    }
  ]
}
{% endschema %}
