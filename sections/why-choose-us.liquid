<section class="section" id="why-choose-us" style="background:var(--color-surface);border-top:1px solid var(--color-border)">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow">{{ section.settings.eyebrow | default: 'Why Ryanz Store' }}</span>
      <h2 class="section-title">{{ section.settings.heading | default: 'Why Shop With Us?' }}</h2>
      <p class="section-subtitle">{{ section.settings.subheading | default: 'We are dedicated to delivering the best gaming experience' }}</p>
    </div>

    <div style="display:grid;grid-template-columns:repeat({{ section.blocks.size | at_most: 4 }},1fr);gap:1.5rem" class="reveal-stagger">
      {%- for block in section.blocks -%}
        <div class="feature-card" {{ block.shopify_attributes }}>
          <div class="feature-card__icon" style="background:rgba({{ block.settings.icon_color | default: '0,212,255' }},0.1);border-color:rgba({{ block.settings.icon_color | default: '0,212,255' }},0.25)">
            {{ block.settings.icon | default: '⚡' }}
          </div>
          <div>
            <h3 class="feature-card__title">{{ block.settings.title | default: 'Feature' }}</h3>
            <p class="feature-card__desc">{{ block.settings.description | default: 'Feature description goes here.' }}</p>
          </div>
        </div>
      {%- else -%}
        {%- assign defaults = 'Fast Shipping:🚀:Orders ship within 24 hours. Free shipping on orders over $75 across the US.,Secure Payments:🔒:Shop safely with SSL encryption. We accept all major cards, PayPal, and more.,Genuine Products:✅:100% authentic gear directly from official brand distributors.,Easy Returns:↩️:Not happy? Return within 30 days for a full refund — no questions asked.,24/7 Support:💬:Our gaming experts are available around the clock to help you choose the right gear.,Warranty Covered:🛡️:All products come with manufacturer warranty. We have your back.' | split: ',' -%}
        {%- for item in defaults -%}
          {%- assign parts = item | split: ':' -%}
          <div class="feature-card">
            <div class="feature-card__icon">{{ parts[1] }}</div>
            <div>
              <h3 class="feature-card__title">{{ parts[0] }}</h3>
              <p class="feature-card__desc">{{ parts[2] }}</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  @media (max-width:1024px) { #why-choose-us [style*="repeat(6"] { grid-template-columns:repeat(3,1fr)!important; } }
  @media (max-width:768px)  { #why-choose-us [style*="repeat("] { grid-template-columns:repeat(2,1fr)!important; } }
  @media (max-width:480px)  { #why-choose-us [style*="repeat("] { grid-template-columns:1fr!important; } }
</style>

{% schema %}
{
  "name": "Why Choose Us",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Why Ryanz Store" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why Shop With Us?" },
    { "type": "text", "id": "subheading", "label": "Subheading" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon (emoji)", "default": "⚡" },
        { "type": "text", "id": "title", "label": "Title", "default": "Feature Title" },
        { "type": "textarea", "id": "description", "label": "Description" },
        { "type": "text", "id": "icon_color", "label": "Icon Color (R,G,B)", "default": "0,212,255" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us",
      "blocks": [
        { "type": "feature", "settings": { "icon": "🚀", "title": "Fast Shipping", "description": "Orders ship within 24 hours. Free shipping on orders over $75." } },
        { "type": "feature", "settings": { "icon": "🔒", "title": "Secure Payments", "description": "Shop safely with SSL encryption and all major payment methods." } },
        { "type": "feature", "settings": { "icon": "✅", "title": "Genuine Products", "description": "100% authentic gear directly from official brand distributors." } },
        { "type": "feature", "settings": { "icon": "↩️", "title": "Easy Returns", "description": "Return within 30 days for a full refund — no questions asked." } },
        { "type": "feature", "settings": { "icon": "💬", "title": "24/7 Support", "description": "Gaming experts available around the clock to help you." } },
        { "type": "feature", "settings": { "icon": "🛡️", "title": "Warranty Covered", "description": "All products come with manufacturer warranty protection." } }
      ]
    }
  ]
}
{% endschema %}
