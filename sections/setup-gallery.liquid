<section class="section" id="setup-gallery">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-eyebrow">{{ section.settings.eyebrow | default: 'Setup Inspiration' }}</span>
      <h2 class="section-title">{{ section.settings.heading | default: 'Level Up Your Battle Station' }}</h2>
      <p class="section-subtitle">{{ section.settings.subheading | default: 'See how elite gamers build their ultimate setups with Ryanz Store gear' }}</p>
    </div>

    <!-- Masonry-style gallery -->
    <div style="
      display:grid;
      grid-template-columns:repeat(4,1fr);
      grid-template-rows:auto;
      gap:1rem;
    " class="reveal-stagger">

      {%- for block in section.blocks -%}
        <div
          class="img-zoom-wrap glass-card glow-border"
          style="
            border-radius:var(--radius-xl);
            overflow:hidden;
            position:relative;
            {% if forloop.index == 1 %}grid-row:span 2;grid-column:span 2;{% elsif forloop.index == 4 %}grid-row:span 2;{% endif %}
            aspect-ratio:{% if forloop.index == 1 %}1{% elsif forloop.index == 4 %}9/16{% else %}4/3{% endif %};
          "
          {{ block.shopify_attributes }}
        >
          {%- if block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | img_url: '800x' }}"
              alt="{{ block.settings.caption | default: 'Gaming Setup' }}"
              loading="lazy"
              width="800"
              height="600"
              style="width:100%;height:100%;object-fit:cover;transition:transform 0.6s ease"
            >
          {%- else -%}
            <div style="width:100%;height:100%;background:linear-gradient(135deg,var(--color-surface-2),var(--color-surface-3));display:flex;align-items:center;justify-content:center;font-size:4rem;">
              🖥️
            </div>
          {%- endif -%}

          <!-- Hover overlay -->
          <div style="
            position:absolute;inset:0;
            background:linear-gradient(0deg, rgba(11,15,25,0.8) 0%, transparent 60%);
            opacity:0;transition:opacity 0.3s ease;
            display:flex;flex-direction:column;justify-content:flex-end;
            padding:1.5rem;
          " class="gallery-overlay">
            {%- if block.settings.caption != blank -%}
              <p style="font-family:var(--font-heading);font-size:1rem;font-weight:600;color:var(--color-text);">
                {{ block.settings.caption }}
              </p>
            {%- endif -%}
            {%- if block.settings.tags != blank -%}
              <div style="display:flex;flex-wrap:wrap;gap:0.4rem;margin-top:0.5rem">
                {%- assign tag_list = block.settings.tags | split: ',' -%}
                {%- for tag in tag_list -%}
                  <span style="font-size:0.7rem;background:rgba(0,212,255,0.15);border:1px solid rgba(0,212,255,0.3);border-radius:9999px;padding:0.2rem 0.6rem;color:var(--color-primary)">{{ tag | strip }}</span>
                {%- endfor -%}
              </div>
            {%- endif -%}
          </div>
        </div>
      {%- else -%}
        <!-- Default placeholder gallery items -->
        {%- assign gallery_items = '🖥️ RGB Desk Setup,🎮 Pro Controller Setup,⌨️ Mechanical Keyboard Corner,💡 RGB Ambient Lighting,🎧 Streaming Station' | split: ',' -%}
        {%- for item in gallery_items -%}
          <div style="
            background:linear-gradient(135deg,var(--color-surface-2),var(--color-surface-3));
            border:1px solid var(--color-border);
            border-radius:var(--radius-xl);
            display:flex;align-items:center;justify-content:center;
            font-size:2rem;
            aspect-ratio:{% if forloop.index == 1 %}1{% else %}4/3{% endif %};
            {% if forloop.index == 1 %}grid-row:span 2;grid-column:span 2;{% endif %}
          ">
            {{ item }}
          </div>
        {%- endfor -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.show_instagram_cta -%}
      <div style="text-align:center;margin-top:2.5rem">
        <a href="{{ section.settings.instagram_url | default: '#' }}" class="btn btn--ghost" target="_blank" rel="noopener noreferrer">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5" stroke="currentColor" stroke-width="2"/>
            <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/>
            <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
          </svg>
          {{ section.settings.instagram_cta | default: 'Follow @ryanzstore for setup inspo' }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .img-zoom-wrap:hover .gallery-overlay { opacity: 1 !important; }
  .img-zoom-wrap:hover img { transform: scale(1.05); }
  @media (max-width:900px) {
    #setup-gallery [style*="grid-template-columns:repeat(4"] { grid-template-columns: repeat(2,1fr) !important; }
    #setup-gallery [style*="grid-row:span 2"] { grid-row: span 1 !important; }
    #setup-gallery [style*="grid-column:span 2"] { grid-column: span 1 !important; }
  }
</style>

{% schema %}
{
  "name": "Setup Gallery",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Setup Inspiration" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Level Up Your Battle Station" },
    { "type": "text", "id": "subheading", "label": "Subheading" },
    { "type": "checkbox", "id": "show_instagram_cta", "label": "Show Instagram CTA", "default": true },
    { "type": "url", "id": "instagram_url", "label": "Instagram URL" },
    { "type": "text", "id": "instagram_cta", "label": "Instagram CTA Text", "default": "Follow @ryanzstore for setup inspo" }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Gallery Image",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "caption", "label": "Caption" },
        { "type": "text", "id": "tags", "label": "Tags (comma separated)", "default": "RGB, Mechanical, Gaming" }
      ]
    }
  ],
  "presets": [{ "name": "Setup Gallery" }]
}
{% endschema %}
